{
  "type": "module",
  "name": "playwright-kit-de-formation",
  "version": "1.0.0",
  "private": true,
  "description": "Kit de formation Playwright en TypeScript (débutant à avancé)",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "playwright test --project=chromium",
    "test:all": "playwright test",
    "test:headed": "playwright test --project=chromium --headed",
    "test:visual": "playwright test --grep @visual",
    "test:a11y": "playwright test --grep @a11y",
    "test:api": "playwright test exercises/advanced-04 solutions/advanced-04 --project=chromium",
    "bdd": "cucumber-js examples/bdd-cucumber/features --require-module ts-node/register --require examples/bdd-cucumber/steps/**/*.ts --format html:examples/bdd-cucumber/reports/cucumber-report.html",
    "coverage": "nyc npm run test:all"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
