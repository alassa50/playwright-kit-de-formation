{
  "name": "playwright-kit-de-formation",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "postCreateCommand": "npm install && npx playwright install --with-deps",
  "customizations": {
    "vscode": {
      "extensions": ["ms-playwright.playwright", "dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
